# FraudPulse configuration
FRAUDPULSE_DB=data/transactions.db
FRAUDPULSE_AUTOSEED=1

# ── Onboarding agent LLM (required for LLM-reasoned dataset onboarding) ──
# Free, no credit card: https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
# Or use Anthropic instead:
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Allow the transparent deterministic engine when no LLM key is set (1 = yes).
# Off by default so the agent never silently falls back to heuristics.
FRAUDPULSE_ALLOW_HEURISTIC=0
